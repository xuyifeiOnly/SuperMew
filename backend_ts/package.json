{
  "name": "supermew-backend-ts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "dev:bun": "bun run ./src/server.ts",
    "dev:tsnode": "node --inspect=9230 --loader ts-node/esm --enable-source-maps ./src/server.ts",
    "start": "pnpm build && node dist/server.js",
    "dev:debug:dist": "pnpm build && node --inspect=9229 --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "ceshi": "bun run ./ceshi/iterator.ts"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,tsx,json",
    "ignore": [
      "dist"
    ],
    "exec": "node --loader ts-node/esm --enable-source-maps ./src/server.ts"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^4.0.0",
    "@koa/router": "^13.1.0",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@zilliz/milvus2-sdk-node": "^2.5.5",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "langchain": "^1.3.1",
    "mammoth": "^1.8.0",
    "nodejieba": "^3.5.8",
    "openai": "^4.79.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "sequelize": "^6.37.5",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-static": "^4.0.4",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
